<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarAI"
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:background="@drawable/bg_gradient"
        android:elevation="8dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_centerVertical="true"
                android:src="@drawable/arrow_back_icon"
                android:tint="@android:color/white" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btnBack"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Music Player"
                    android:textColor="@android:color/white"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enjoy Farming Music 🎵"
                    android:textColor="#E8F5E9"
                    android:textSize="13sp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/more_vert_icon"
                android:tint="@android:color/white" />

        </RelativeLayout>

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#EEF5EE"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvEntertainmentSongName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pai Fukata"
                android:textAlignment="center"
                android:textColor="#222222"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvArtistName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="6dp"
                android:text="Artist • AgroGuide Music"
                android:textColor="#757575"
                android:textSize="15sp" />

            <androidx.cardview.widget.CardView
                android:layout_width="320dp"
                android:layout_height="320dp"
                android:layout_gravity="center"
                android:layout_marginTop="22dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="14dp">

                <ImageView
                    android:id="@+id/ivEntertenmentsongcoverpage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/pai_fukata" />

            </androidx.cardview.widget.CardView>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvEntertenmentsongstarttime"
                    android:layout_width="45dp"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#2E7D32"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <SeekBar
                    android:id="@+id/sbEntertenmentSongProgress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:progressTint="#4CAF50"
                    android:thumbTint="#4CAF50" />

                <TextView
                    android:id="@+id/tvEntertenmentsongendtime"
                    android:layout_width="45dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="04:17"
                    android:textColor="#2E7D32"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/ibEntertenmentPreviousSong"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_margin="5dp"
                    android:background="@android:color/transparent"
                    android:padding="10dp"
                    android:src="@drawable/previous_icon" />

                <ImageButton
                    android:id="@+id/ibEntertenmentBackwardSong"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_margin="5dp"
                    android:background="@android:color/transparent"
                    android:padding="10dp"
                    android:src="@drawable/backword_icon" />

                <androidx.cardview.widget.CardView
                    android:layout_width="85dp"
                    android:layout_height="85dp"
                    android:layout_margin="12dp"
                    app:cardCornerRadius="45dp"
                    app:cardElevation="15dp">

                    <ImageButton
                        android:id="@+id/ibEntertainmentPlay"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_gradient"
                        android:padding="18dp"
                        android:src="@drawable/play_icon"
                        android:tint="@android:color/white" />

                </androidx.cardview.widget.CardView>

                <ImageButton
                    android:id="@+id/ibEnertenmentForward"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_margin="5dp"
                    android:background="@android:color/transparent"
                    android:padding="10dp"
                    android:src="@drawable/forward_icon" />

                <ImageButton
                    android:id="@+id/ibEntertenmentNext"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_margin="5dp"
                    android:background="@android:color/transparent"
                    android:padding="10dp"
                    android:src="@drawable/next_icon" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnShuffle"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_margin="12dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/shuffle_icon"
                    android:tint="#4CAF50" />

                <ImageButton
                    android:id="@+id/btnFavourite"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_margin="12dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/favorite_border"
                    android:tint="#E91E63" />

                <ImageButton
                    android:id="@+id/btnRepeat"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_margin="12dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/repeat_icon"
                    android:tint="#4CAF50" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="12dp"
                android:text="🎵 Playlist"
                android:textColor="#1B5E20"
                android:textSize="22sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="320dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="22dp"
                app:cardElevation="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/etSearchSong"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_margin="12dp"
                        android:background="@drawable/edittext_bg"
                        android:drawablePadding="10dp"
                        android:drawableStart="@drawable/search_icon"
                        android:hint="Search Song..."
                        android:paddingStart="15dp"
                        android:textColor="#000000"
                        android:textColorHint="#777777" />

                    <ListView
                        android:id="@+id/listSongs"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:divider="#E8E8E8"
                        android:dividerHeight="1dp"
                        android:listSelector="?android:attr/selectableItemBackground"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:scrollbars="none" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="🎧 Enjoy Your Favorite Music"
                android:textColor="#4CAF50"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="AgroGuide Entertainment"
                android:textColor="#777777"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>